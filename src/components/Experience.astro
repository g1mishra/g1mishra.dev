---
import { experience, meta } from "../data/portfolio";
---

<section id="work" class="reveal scroll-mt-24 border-b border-border py-16 sm:py-24">
  <div class="mb-12 flex items-end justify-between gap-6">
    <h2 class="font-display text-4xl sm:text-5xl font-semibold text-ink">Work</h2>
    <a
      class="hidden text-sm font-semibold text-amber underline decoration-amber/40 underline-offset-4 transition hover:decoration-amber sm:inline"
      href={meta.resumeUrl}
    >
      Full resume →
    </a>
  </div>
  <div class="divide-y divide-border">
    {
      experience.map((item, i) => (
        <article class="group grid gap-3 py-6 sm:grid-cols-[1.2fr_2fr_auto] sm:items-baseline transition-colors hover:bg-card-hover -mx-4 px-4 rounded-xl" style={`animation-delay: ${0.1 * i}s`}>
          <div>
            <h3 class="text-lg font-semibold text-ink transition-colors group-hover:text-amber">{item.company}</h3>
            <p class="text-sm text-muted">{item.role}</p>
          </div>
          <p class="text-lg leading-7 text-ink/80">{item.summary}</p>
          <p class="font-mono text-xs font-semibold uppercase tracking-[0.12em] text-muted w-28 sm:text-right mt-2 sm:mt-0">
            {item.period}
          </p>
        </article>
      ))
    }
  </div>
  <a
    class="mt-8 inline-flex text-sm font-semibold text-amber underline decoration-amber/40 underline-offset-4 transition hover:decoration-amber sm:hidden"
    href={meta.resumeUrl}
  >
    Full resume →
  </a>
</section>
