---
import { modes } from "../data/portfolio";

const modeIcons: Record<string, string> = {
  Engineer: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/></svg>`,
  Builder: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>`,
  Creator: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2"/></svg>`,
};

const modeBgClasses: Record<string, string> = {
  Engineer: "bg-card",
  Builder: "builder-card bg-amber-light border-amber/20",
  Creator: "bg-paper",
};
---

<section class="reveal border-b border-border py-16 sm:py-24 relative">
  <!-- Subtle amber band stretching full width behind -->
  <div class="modes-band absolute inset-0 bg-gradient-to-r from-transparent via-amber-light to-transparent opacity-50 pointer-events-none -z-10"></div>
  
  <div class="grid gap-6 sm:grid-cols-3">
    {
      modes.map((mode, i) => (
        <article class={`rounded-2xl p-8 border border-border shadow-sm transition-transform duration-300 hover:-translate-y-2 ${modeBgClasses[mode.label] || "bg-card"}`} style={`animation-delay: ${0.1 * i}s`}>
          <div class="text-amber bg-white/10 dark:bg-black/10 inline-flex p-3 rounded-xl border border-border">
            <span set:html={modeIcons[mode.label]} />
          </div>
          <h2 class="mt-6 font-display text-3xl font-semibold text-ink">{mode.label}</h2>
          <p class="mt-3 text-base leading-7 text-muted">{mode.oneliner}</p>
        </article>
      ))
    }
  </div>
</section>

<style>
  /* Fix muddy dark mode appearance */
  :global([data-theme="dark"]) .modes-band {
    opacity: 0.05 !important;
  }
  
  :global([data-theme="dark"]) .builder-card {
    background-color: rgba(245, 169, 51, 0.05) !important;
    border-color: rgba(245, 169, 51, 0.2) !important;
  }
</style>
