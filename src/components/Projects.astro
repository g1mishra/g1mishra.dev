---
import { projects } from "../data/portfolio";
---

<section id="projects" class="reveal scroll-mt-24 border-b border-border py-16 sm:py-24">
  <h2 class="font-display text-4xl sm:text-5xl font-semibold text-ink">Projects</h2>
  <div class="mt-12 divide-y divide-border">
    {
      projects.map((project, i) => (
        <article class="group relative grid gap-4 py-8 sm:grid-cols-[1fr_2fr_auto] sm:items-baseline transition-colors hover:bg-card-hover -mx-4 px-4 rounded-xl overflow-hidden" style={`animation-delay: ${0.1 * i}s`}>
          <!-- Hover sliding border -->
          <div class="absolute left-0 top-0 bottom-0 w-1 bg-amber -translate-x-full transition-transform duration-300 ease-out group-hover:translate-x-0"></div>
          
          <h3 class="font-display text-2xl font-semibold text-ink group-hover:text-amber transition-colors">{project.name}</h3>
          <div>
            <p class="text-lg leading-7 text-muted group-hover:text-ink/90 transition-colors">{project.description}</p>
            <div class="mt-4 flex flex-wrap gap-3">
              {project.tags.map((tag) => (
                <span class="font-mono text-xs font-semibold uppercase tracking-widest text-muted/80">
                  {tag}
                </span>
              ))}
            </div>
          </div>
          {project.links.live ? (
            <a
              class="text-sm font-semibold text-amber underline decoration-amber/0 underline-offset-4 transition group-hover:decoration-amber mt-2 sm:mt-0"
              href={project.links.live as string}
              target="_blank"
              rel="noopener noreferrer"
            >
              Live →
            </a>
          ) : (
            <div class="text-sm font-semibold text-muted italic opacity-0 mt-2 sm:mt-0">Not live</div>
          )}
        </article>
      ))
    }
  </div>
</section>
