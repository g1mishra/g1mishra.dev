---
import { meta } from "../data/portfolio";
import { Image } from "astro:assets";
import jeevanPhoto from "../assets/jeevan-photo.png";
---

<section class="grid min-h-[78vh] content-center border-y border-border py-20 sm:py-28">
  <div class="grid gap-12 sm:grid-cols-[1fr_auto] sm:items-center">
    
    <div class="order-2 sm:order-1 max-w-3xl">
      {
        meta.availability && (
          <p class="mb-8 inline-flex items-center gap-2 rounded-full border border-border bg-card px-4 py-2 font-mono text-xs font-semibold uppercase tracking-[0.12em] text-ink">
            <span class="relative flex h-2.5 w-2.5">
              <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-75" />
              <span class="relative inline-flex h-2.5 w-2.5 rounded-full bg-emerald-500" />
            </span>
            Open to work — remote or relocation
          </p>
        )
      }
      <h1 class="font-display text-[clamp(2.75rem,6vw,5rem)] font-semibold leading-[1.05] tracking-normal text-ink reveal" style="animation-delay: 0.1s">
        {meta.tagline}
      </h1>
      <p class="mt-8 max-w-2xl text-xl leading-8 text-muted sm:text-2xl sm:leading-9 reveal" style="animation-delay: 0.2s">
        {meta.subline}
      </p>
      <div class="mt-10 flex items-center gap-6 reveal" style="animation-delay: 0.3s">
        <a
          href="#work"
          class="rounded-full bg-ink px-6 py-2.5 text-sm font-semibold !text-[var(--color-paper)] transition hover:bg-ink/80"
        >
          See my work ↓
        </a>
        <a
          href={`mailto:${meta.email}`}
          class="text-sm font-medium text-muted transition hover:text-amber"
        >
          Say Hi →
        </a>
      </div>
    </div>

    <div class="order-1 sm:order-2 reveal" style="animation-delay: 0.4s">
      <div class="relative w-48 h-64 sm:w-64 sm:h-80 rotate-2 transition-transform duration-500 hover:rotate-0 hover:scale-105">
        <div class="absolute inset-0 bg-amber-light rounded-2xl rotate-3 -z-10"></div>
        <Image 
          src={jeevanPhoto} 
          alt={meta.photoAlt} 
          class="w-full h-full object-cover rounded-2xl border border-border shadow-xl filter contrast-105"
          width={400}
          height={500}
        />
      </div>
    </div>

  </div>
</section>
